# Infra
POSTGRES_DB=liquidacion_granos
POSTGRES_USER=liquidacion
POSTGRES_PASSWORD=liquidacion

# Backend
FLASK_ENV=development
FLASK_DEBUG=1
TZ=America/Argentina/Cordoba
SECRET_KEY=change-me
CLIENT_SECRET_KEY=change-this-in-local-env
DATABASE_URL=postgresql+psycopg://liquidacion:liquidacion@postgres:5432/liquidacion_granos
REDIS_URL=redis://redis:6379/0
CLIENT_CERTIFICATES_BASE_PATH=/app/certificados_clientes

# CORS
CORS_ORIGINS=http://localhost:5173

# ARCA / WSLPG
ARCA_ENVIRONMENT=homologacion
ARCA_SERVICE_NAME=wslpg
ARCA_WSDL_URL=
ARCA_CUIT_REPRESENTADA=
ARCA_CERT_PATH=/app/data/certificado.crt
ARCA_KEY_PATH=/app/data/private.key
ARCA_KEY_PASSPHRASE=
ARCA_TA_PATH=/app/data/ta

# Playwright (UI ARCA)
# false/0/no = browser headed bajo Xvfb (mejor anonimato, ~2x RAM). Cualquier otro valor = headless. Default headless.
PLAYWRIGHT_HEADLESS=1
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_TYPE_DELAY_MS=80
PLAYWRIGHT_SLOW_MO_MS=0
PLAYWRIGHT_POST_ACTION_DELAY_MS=0
PLAYWRIGHT_LOGIN_MAX_RETRIES=1

# Scheduler
# Ventana de jitter para repartir las extracciones del scheduler (segundos). Default 10800 = 3h (03:00-06:00).
SCHEDULER_JITTER_WINDOW_SECONDS=10800
